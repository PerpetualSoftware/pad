		"marked": "^18.0.5",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"typescript": "^6.0.3",
		"vite": "^8.1.0",
		"vitest": "3.2.6"
	},
	"overrides": {
